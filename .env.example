# Kiro Proxy Go - Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Settings
# =============================================================================

# Host to listen on (default: 0.0.0.0)
# SERVER_HOST=0.0.0.0

# Port to listen on (default: 8000)
# SERVER_PORT=8000

# =============================================================================
# Proxy Authentication
# =============================================================================

# API key that clients must provide to access this proxy
# Clients send this as: Authorization: Bearer <key>
PROXY_API_KEY=my-super-secret-password-123

# =============================================================================
# Kiro API Credentials
# =============================================================================

# Option 1 (recommended): Path to kiro-cli credentials file
# After running `kiro-cli login`, the token is written here.
# The proxy reads this file on each request and auto-refreshes when needed.
KIRO_CREDS_FILE="~/.aws/sso/cache/kiro-auth-token-cli.json"

# Option 2: Direct refresh token (alternative to file)
# REFRESH_TOKEN=

# =============================================================================
# Region Settings
# =============================================================================

# AWS region for SSO/auth endpoint (default: us-east-1)
# Usually auto-detected from the credentials file.
# KIRO_REGION=us-east-1

# Override the Q API region (use when SSO region differs from Q API region)
# If not set, defaults to the auth region (from file or KIRO_REGION).
# KIRO_API_REGION=us-east-1

# =============================================================================
# Timeouts & Retry
# =============================================================================

# Timeout waiting for first token from Kiro (seconds, default: 15)
# FIRST_TOKEN_TIMEOUT=15

# Read timeout for streaming responses (seconds, default: 300)
# STREAMING_READ_TIMEOUT=300

# Max retry attempts (default: 3)
# MAX_RETRIES=3

# =============================================================================
# Features
# =============================================================================

# Enable fake reasoning / thinking tag injection (default: true)
# FAKE_REASONING=true

# Max thinking tokens budget (default: 4000)
# FAKE_REASONING_MAX_TOKENS=4000

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
